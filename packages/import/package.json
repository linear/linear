{
  "name": "@linear/import",
  "description": "Import helpers for uploading issues to Linear",
  "version": "3.2.4",
  "author": "Linear Orbit, Inc",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "bin": {
    "linear-import": "bin/linear-import.cjs"
  },
  "repository": "https://github.com/linear/linear",
  "engines": {
    "node": ">=18.x"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "cli": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm src/cli.ts",
    "cli:local": "NODE_TLS_REJECT_UNAUTHORIZED=0 TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm src/cli.ts --apiUrl https://local.linear.dev:8090/graphql",
    "build:import": "tsdown --clean --format cjs src/cli.ts",
    "build:types": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest"
  },
  "dependencies": {
    "@linear/sdk": "workspace:*",
    "chalk": "4.1.2",
    "cli-progress": "^3.12.0",
    "csvtojson": "2.0.13",
    "date-fns": "^2.19.0",
    "inquirer": "7.3.3",
    "inquirer-file-path": "1.0.1",
    "jira2md": "3.0.1",
    "lodash": "4.18.1",
    "node-fetch": "2.6.7",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^7.3.3",
    "@types/node-fetch": "^2.5.7",
    "tsdown": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "ac77c2c674a4266bd263b18213354572d3e8f9eb"
}
